# =============================================================
# OncoFix Backend Configuration
# Edit this file, then restart: sudo systemctl restart oncofix-backend
# =============================================================

# Application
NODE_ENV=production
PORT=3000
APP_NAME=OncoFix Online Backend
APP_VERSION=2.0.0

# Database - offline mode with SQLite
DATABASE_MODE=offline
SQLITE_DATABASE_PATH=/var/lib/oncofix/database.sqlite

# Sync - enabled (syncs to BigQuery when internet available)
SYNC_ENABLED=true

# HTTPS - disabled (running behind local network)
HTTPS_ENABLED=false

# JWT - CHANGE THESE IN PRODUCTION!
JWT_SECRET=CHANGE-THIS-TO-A-STRONG-RANDOM-SECRET
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE-THIS-TO-ANOTHER-STRONG-SECRET
JWT_REFRESH_EXPIRES_IN=30d

# API
API_PREFIX=api/v1
API_VERSION=2.0.0

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DEST=/opt/oncofix/oncofix_online_backend/uploads
ALLOWED_FILE_TYPES=pdf,doc,docx,txt,jpg,jpeg,png,gif

# Photo Encryption - CHANGE THIS!
PHOTO_ENCRYPTION_KEY=CHANGE-THIS-32-CHAR-MINIMUM-KEY!!
PUBLIC_PHOTOS_DIR=/opt/oncofix/oncofix_online_backend/public/photos

# Device
DEFAULT_DEVICE_ID=OPi5_oncofix_default_001

# RabbitMQ (optional - sync falls back to direct BigQuery if unavailable)
RABBITMQ_URL=amqp://localhost
RABBITMQ_PREFETCH=1
RABBITMQ_MAX_RETRIES=3
RABBITMQ_RETRY_TTL_MS=30000

# BigQuery Sync - EDIT THESE
BIGQUERY_PROJECT_ID=oncoedge-479901
BIGQUERY_DATASET=oncoedge_test
BIGQUERY_TABLE_PREFIX=
BIGQUERY_CREDENTIALS_PATH=/opt/oncofix/oncofix_online_backend/bigquery-credentials.json

# Sync Backup
SYNC_BACKUP_DIR=/opt/oncofix/oncofix_online_backend/backups
SYNC_BACKUP_RETAIN_DAYS=30
CLEANUP_LOCAL_PHOTO_AFTER_SYNC=true

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/oncofix/app.log
